# MASSIVE (Polygon-compatible) credentials for the Assay data pipeline.
#
# Two ways to provide these:
#   1. Export them from your shell profile (the installer appended a block to
#      ~/.bashrc). Run `source ~/.bashrc` once, and every shell will have them.
#   2. Copy this file to `.env` (which is git-ignored) and fill in the values.
#      `assay.config` loads `.env` automatically without overriding the shell env.

# REST API key (Bearer token for https://api.massive.com)
MASSIVE_API_KEY=your-massive-api-key

# S3 flat-files credentials (https://files.massive.com, bucket: flatfiles)
MASSIVE_S3_ACCESS_KEY_ID=your-s3-access-key-id
MASSIVE_S3_SECRET_ACCESS_KEY=your-s3-secret-access-key

# Endpoints / bucket (defaults shown; override only if MASSIVE changes them)
MASSIVE_S3_ENDPOINT=https://files.massive.com
MASSIVE_S3_BUCKET=flatfiles
MASSIVE_REST_BASE_URL=https://api.massive.com

# Where the prepared parquet stores are written (default: ./data)
ASSAY_DATA_DIR=data
