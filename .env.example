# Assay data-pipeline configuration.
#
# The pipeline transforms a LOCAL mirror of the MASSIVE dataset (downloaded
# out-of-band by the downloader_* scripts) into the Assay parquet stores — it
# does not download anything itself, so no credentials are required.
#
# Copy this file to `.env` (git-ignored) to override the defaults; `assay.config`
# loads `.env` automatically without overriding values already in the shell env.

# Root of the local MASSIVE mirror (default: /data/massive_data). Expected layout:
#   $MASSIVE_DATA_DIR/us_stocks_sip/day_aggs_v1/{YYYY}/{MM}/{YYYY-MM-DD}.parquet
#   $MASSIVE_DATA_DIR/corporate_actions/splits/{TICKER}.jsonl
#   $MASSIVE_DATA_DIR/corporate_actions/dividends/{TICKER}.jsonl
MASSIVE_DATA_DIR=/data/massive_data

# Where the prepared parquet stores are written (default: ./data)
ASSAY_DATA_DIR=data

# --- Tushare (Chinese A-share + Hong Kong raw data download) ---------------
# Only needed to run scripts/download_tushare.py. Get a token at
# https://tushare.pro/ . NEVER commit a real token — keep it in .env (git-ignored).
TUSHARE_TOKEN=your_tushare_token_here
# Root of the local Tushare raw mirror (default: /data/tushare_data). Layout:
#   $TUSHARE_DATA_DIR/cn/{daily,adj_factor,daily_basic,dividend}/{ts_code}.parquet
#   $TUSHARE_DATA_DIR/cn/index_weight/{CSI300,CSI500,CSI1000}.parquet
#   $TUSHARE_DATA_DIR/hk/{daily,index_global,constituents}.parquet
#   $TUSHARE_DATA_DIR/meta/{stock_basic,hk_basic,trade_cal}.parquet
TUSHARE_DATA_DIR=/data/tushare_data
# Optional backfill window (YYYYMMDD). Defaults: start 20100101, end = today.
TUSHARE_START=20100101
# TUSHARE_END=20260627
